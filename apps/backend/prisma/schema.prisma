generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SOCIETE ───────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  legalName String?
  vatNumber String?
  address   String?
  phone     String?
  email     String?
  logo      String?
  currency  String   @default("EUR")
  timezone  String   @default("Europe/Luxembourg")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      UserCompany[]
  tables     Table[]
  categories Category[]
  products   Product[]
  orders     Order[]
  settings   CompanySettings?
}

model CompanySettings {
  id             String  @id @default(cuid())
  companyId      String  @unique
  posMode        String  @default("restaurant")
  taxRate1       Float   @default(3)
  taxRate2       Float   @default(8)
  taxRate3       Float   @default(14)
  taxRate4       Float   @default(17)
  defaultTaxRate Float   @default(17)
  currency       String  @default("EUR")
  receiptFooter  String?
  printerIp      String?

  company Company @relation(fields: [companyId], references: [id])
}

// ─── UTILISATEURS ──────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies     UserCompany[]
  orders        Order[]
  refreshTokens RefreshToken[]
}

model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("EMPLOYEE")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PLAN DE SALLE ─────────────────────────────────────

model Table {
  id        String   @id @default(cuid())
  companyId String
  name      String
  section   String   @default("Salle")
  capacity  Int      @default(4)
  posX      Float    @default(0)
  posY      Float    @default(0)
  width     Float    @default(120)
  height    Float    @default(120)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  orders  Order[]
}

// ─── CATALOGUE PRODUITS ────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  companyId String
  name      String
  icon      String?
  color     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  company  Company   @relation(fields: [companyId], references: [id])
  products Product[]
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  categoryId  String
  name        String
  description String?
  price       Float
  taxRate     Float    @default(17)
  image       String?
  allergens   String[] @default([])
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  stock       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company    Company     @relation(fields: [companyId], references: [id])
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]
}

// ─── COMMANDES ─────────────────────────────────────────

model Order {
  id            String    @id @default(cuid())
  companyId     String
  tableId       String?
  userId        String
  orderNumber   Int
  status        String    @default("OPEN")
  notes         String?
  subtotal      Float     @default(0)
  taxAmount     Float     @default(0)
  total         Float     @default(0)
  paidAt        DateTime?
  paymentMethod String?
  cashReceived  Float?
  cashChange    Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company Company     @relation(fields: [companyId], references: [id])
  table   Table?      @relation(fields: [tableId], references: [id])
  user    User        @relation(fields: [userId], references: [id])
  items   OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  taxRate   Float
  notes     String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}
