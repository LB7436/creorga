# ─── Database ─────────────────────────────────────────────────────────────
# Leave empty to run without DB (fallback admin will be used).
DATABASE_URL="postgresql://creorga:password@localhost:5433/creorga_dev"

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET="dev-jwt-secret-creorga-change-in-production"
JWT_REFRESH_SECRET="dev-refresh-secret-creorga-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Server ───────────────────────────────────────────────────────────────
PORT="3002"
NODE_ENV="development"
FRONTEND_URL="http://localhost:5174"

# ─── Fallback admin (works when DB is offline) ────────────────────────────
FALLBACK_ADMIN_EMAIL="admin@creorga.local"
FALLBACK_ADMIN_PASSWORD="Admin1234!"

# ─── Stripe (optional) ────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""

# ─── Email (Resend, optional) ─────────────────────────────────────────────
# RESEND_API_KEY=""
# EMAIL_FROM="Creorga <no-reply@creorga.lu>"

# ─── Payment gateways (optional) ──────────────────────────────────────────
# SUMUP_AFFILIATE_KEY=""
# MYPOS_SID=""
# MYPOS_WALLET=""
# VIVA_MERCHANT_ID=""
# VIVA_API_KEY=""
# VIVA_ENV="demo"
# WORLDLINE_API_USER=""
# WORLDLINE_API_PASS=""
# WORLDLINE_CUSTOMER_ID=""
# WORLDLINE_TERMINAL_ID=""
# SERVIPAY_MERCHANT_ID=""
# SERVIPAY_API_KEY=""
